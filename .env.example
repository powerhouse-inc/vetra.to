# The homepage is hosted externally and redirects to this URL when accessed
# This environment variable stores the external homepage URL
HOMEPAGE_REMOTE_URL=https://understanding-assistant-316991.framer.app/page

# Switchboard GraphQL API URL (for builder teams and packages)
NEXT_PUBLIC_SWITCHBOARD_URL=https://switchboard.staging.vetra.io/graphql

# Renown API URL (for user profile data)
NEXT_PUBLIC_RENOWN_URL=https://renown-staging.vetra.io

# Cloud environments switchboard URL (defaults to NEXT_PUBLIC_SWITCHBOARD_URL)
# NEXT_PUBLIC_CLOUD_SWITCHBOARD_URL=https://switchboard.staging.vetra.io/graphql

# Cloud environments drive ID
NEXT_PUBLIC_CLOUD_DRIVE_ID=powerhouse
