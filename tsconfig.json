{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@/shared/*": ["./modules/shared/*"],
      "@powerhousedao/vetra-cloud-package/document-models": [
        "./node_modules/@powerhousedao/vetra-cloud-package/dist/document-models/index.d.ts"
      ],
      "@powerhousedao/vetra-cloud-package/document-models/*": [
        "./node_modules/@powerhousedao/vetra-cloud-package/dist/document-models/*/index.d.ts"
      ]
    }
  },
  "include": ["**/*", ".next/types/**/*.ts", ".next/dev/types/**/*.ts"],
  "exclude": ["node_modules", "modules/__generated__", "tests", "playwright.config.ts"]
}
